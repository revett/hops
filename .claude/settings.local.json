{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(biome *)",
      "Bash(make *)",
      "Bash(git *)",
      "Bash(./hops *)",
      "Bash(HOPS_CONFIG=* ./hops*)",
      "Edit",
      "MultiEdit",
      "WebFetch",
      "WebSearch",
      "Write"
    ]
  },
  "env": {
    "HOPS_CONFIG": "./hops.example.yml"
  }
}
